# ── Required ───────────────────────────────────────────────────────────────────

# OpenAI API key for the LangGraph agent (GPT-4.1-mini)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Virtual Try-On backend — set ONE of the following ─────────────────────────

# Option A (recommended): FASHN API — $0.075/image, 10 free credits on sign-up
# https://fashn.ai → Dashboard → API Keys
FASHN_API_KEY=

# Option B: Replicate + IDM-VTON — ~$0.025/prediction (non-commercial license)
# https://replicate.com → Account → API Tokens
REPLICATE_API_TOKEN=

# ── Image upload (required for Try-On when using uploaded photos) ──────────────

# imgbb API key — free tier, no expiry on uploaded images
# https://api.imgbb.com → get API key
IMGBB_API_KEY=

# ── Production / deployment (optional for local dev) ──────────────────────────

# Comma-separated list of allowed frontend origins (CORS)
# Default: http://localhost:5173,http://localhost:4173
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Backend URL used by the Vite dev proxy
# Default: http://localhost:8000
# VITE_API_URL=https://your-api.onrender.com

# Authentication database.
# Local fallback is sqlite:///./auth.db.
# Aiven MySQL SQLAlchemy URL format:
# DATABASE_URL=mysql+pymysql://avnadmin:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/defaultdb
DATABASE_URL=

# JWT signing secret for login sessions. Use a long random value in production.
JWT_SECRET_KEY=

# Optional: access token lifetime in minutes. Default is 43200 (30 days).
ACCESS_TOKEN_EXPIRE_MINUTES=43200
